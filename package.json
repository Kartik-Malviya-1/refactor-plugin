{
  "name": "refactor-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:ui": "vite build",
    "build:plugin": "vite build --mode plugin",
    "build": "pnpm run build:ui && pnpm run build:plugin",
    "dev": "concurrently -n ui,plugin -c cyan,magenta \"pnpm run build:ui -- --watch\" \"pnpm run build:plugin -- --watch\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.10.8",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.101.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.2"
  }
}
